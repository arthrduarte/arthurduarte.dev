# Database (Neon Postgres)
STORAGE_DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
# Optional direct connection for drizzle-kit migrations (recommended for Neon)
STORAGE_DATABASE_URL_UNPOOLED=postgresql://user:pass@host/db?sslmode=require

# Admin auth
SESSION_SECRET=replace-with-a-long-random-string
DASHBOARD_PASSWORD=replace-with-a-strong-password
# Optional hashed password instead of plain text:
# DASHBOARD_PASSWORD_HASH=scrypt:salt:hash

# Vercel Blob (required for pasted/uploaded archive images)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
